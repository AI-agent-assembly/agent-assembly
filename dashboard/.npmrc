# pnpm configuration for the dashboard workspace
#
# shamefully-hoist=false (default)
#   Keep pnpm's strict node_modules layout. Dependencies are NOT hoisted to
#   the root node_modules, which prevents phantom-dependency bugs where code
#   accidentally imports a package it does not declare in package.json.
#
# strict-peer-dependencies=false
#   Peer dependency warnings are printed but do not abort the install.
#   React 18 + Vite toolchain sometimes has transitional peer mismatches;
#   set to true once the ecosystem fully catches up.
#
# auto-install-peers=true
#   Automatically install missing peer dependencies declared by packages.
#   Avoids manual resolution for well-known peer chains (e.g. @types/*).

shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
